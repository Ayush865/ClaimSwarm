# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── LLM Provider + Model Tiers ──────────────────────────────────────────────
#
# Each agent uses the model tier sized for its reasoning load:
#   fast      → Aggregator (1-sentence summary, trivial)
#   balanced  → Extractor, GitHub Verifier (classification + pattern matching)
#   reasoning → Public Verifier, Internal Consistency Checker (critical evaluation,
#               resisting false positives, detecting impossible timelines)
#
# If you only set LLM_MODEL (or GROQ_API_KEY), all three tiers use that one model.
# Set the tier vars to split workloads across model sizes.

# Option A: Groq
GROQ_API_KEY=gsk_...
# LLM_MODEL_FAST=llama-3.1-8b-instant
# LLM_MODEL_BALANCED=llama-3.1-70b-versatile
# LLM_MODEL_REASONING=llama-3.3-70b-versatile

# Option B: NVIDIA NIM (recommended — 1000 free req credits)
# Get key at: https://build.nvidia.com → "Get API Key"
# LLM_BASE_URL=https://integrate.api.nvidia.com/v1
# LLM_API_KEY=nvapi-...
# LLM_MODEL_FAST=meta/llama-3.1-8b-instruct
# LLM_MODEL_BALANCED=meta/llama-3.1-70b-instruct
# LLM_MODEL_REASONING=meta/llama-3.1-405b-instruct

# Option C: DeepSeek (cheap paid)
# LLM_BASE_URL=https://api.deepseek.com
# LLM_API_KEY=sk-...
# LLM_MODEL_FAST=deepseek-chat
# LLM_MODEL_BALANCED=deepseek-chat
# LLM_MODEL_REASONING=deepseek-reasoner

# Serper (web search grounding)
SERPER_API_KEY=...

# GitHub (OSS claim verification)
GITHUB_TOKEN=github_pat_...

# Swarm tuning
# Free Groq:    SWARM_POOL=1  SWARM_BATCH_SIZE=10  SWARM_GAP_MS=13000
# NVIDIA NIM:   SWARM_POOL=4  SWARM_BATCH_SIZE=20  SWARM_GAP_MS=1000
# DeepSeek paid: SWARM_POOL=5 SWARM_BATCH_SIZE=20  SWARM_GAP_MS=500
SWARM_POOL=1
SWARM_BATCH_SIZE=10
SWARM_GAP_MS=13000
