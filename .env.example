# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── LLM Provider (pick ONE block) ───────────────────────────────────────────

# Option A: Groq (default — free tier 6000 TPM, slow)
GROQ_API_KEY=gsk_...
# LLM_MODEL=llama-3.1-8b-instant

# Option B: NVIDIA NIM (recommended free tier — 1000 req credits, fast)
# Get key at: https://build.nvidia.com → "Get API Key"
# LLM_BASE_URL=https://integrate.api.nvidia.com/v1
# LLM_API_KEY=nvapi-...
# LLM_MODEL=meta/llama-3.1-8b-instruct

# Option C: DeepSeek (cheap paid — $0.07/M tokens for deepseek-chat)
# LLM_BASE_URL=https://api.deepseek.com
# LLM_API_KEY=sk-...
# LLM_MODEL=deepseek-chat

# Serper (web search grounding)
SERPER_API_KEY=...

# GitHub (OSS claim verification)
GITHUB_TOKEN=github_pat_...

# Swarm tuning
# Free Groq:    SWARM_POOL=1  SWARM_BATCH_SIZE=10  SWARM_GAP_MS=13000
# NVIDIA NIM:   SWARM_POOL=4  SWARM_BATCH_SIZE=20  SWARM_GAP_MS=1000
# DeepSeek paid: SWARM_POOL=5 SWARM_BATCH_SIZE=20  SWARM_GAP_MS=500
SWARM_POOL=1
SWARM_BATCH_SIZE=10
SWARM_GAP_MS=13000
